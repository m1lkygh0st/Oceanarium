  rankdir="LR";
  Node0 [id="Node000000",label="Fish",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_fish.html",tooltip="Базовый класс рыбы в океанариуме."];
  Node0 -> Node1 [id="edge1_Node000000_Node000001",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node1 [id="Node000001",label="Angelfish",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_angelfish.html",tooltip="Вид рыбы — скалярия."];
  Node0 -> Node2 [id="edge2_Node000000_Node000002",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node2 [id="Node000002",label="Butterflyfish",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_butterflyfish.html",tooltip="Рыба — рыба-бабочка."];
  Node0 -> Node3 [id="edge3_Node000000_Node000003",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node3 [id="Node000003",label="Cardinalfish",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_cardinalfish.html",tooltip="Рыба — кардинал."];
  Node0 -> Node4 [id="edge4_Node000000_Node000004",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node4 [id="Node000004",label="Salmon",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_salmon.html",tooltip="Рыба — лосось."];
  Node0 -> Node5 [id="edge5_Node000000_Node000005",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node5 [id="Node000005",label="Shark",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_shark.html",tooltip="Рыба — акула."];
}
